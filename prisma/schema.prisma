generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model FoodEntry {
  id        String   @id @default(cuid())
  name      String
  calories  Int
  protein   Float    @default(0)
  carbs     Float    @default(0)
  fat       Float    @default(0)
  fiber     Float    @default(0)
  serving   String?
  mealType  String   @default("snack")
  imageUrl  String?
  source    String   @default("text")
  date      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DailyGoal {
  id             String   @id @default(cuid())
  date           String   @unique
  calorieTarget  Int      @default(2000)
  proteinTarget  Float    @default(150)
  carbTarget     Float    @default(250)
  fatTarget      Float    @default(65)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}