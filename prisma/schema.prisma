generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model FoodEntry {
  id        String   @id @default(cuid())
  name      String
  calories  Int
  protein   Float    @default(0)
  carbs     Float    @default(0)
  fat       Float    @default(0)
  fiber     Float    @default(0)
  serving   String?
  mealType  String   @default("snack")
  imageUrl  String?
  source    String   @default("text")
  date      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DailyGoal {
  id             String   @id @default(cuid())
  date           String   @unique
  calorieTarget  Int      @default(2000)
  proteinTarget  Float    @default(150)
  carbTarget     Float    @default(250)
  fatTarget      Float    @default(65)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model UserProfile {
  id        String  @id @default(cuid())
  name      String  @default("User")
  age       Int     @default(25)
  weight    Float   @default(70)
  height    Float   @default(170)
  gender    String  @default("male")
  activity  String  @default("moderate")
  bmr       Float   @default(0)
  tdee      Float   @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WaterLog {
  id        String   @id @default(cuid())
  amount    Int
  date      String
  createdAt DateTime @default(now())
}

model Badge {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String
  icon        String
  unlockedAt  DateTime?
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String
  content   String
  createdAt DateTime @default(now())
}